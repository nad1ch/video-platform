{
  "name": "video-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test:wordle": "npm run test -w wordle-consistency",
    "test:eat-first": "npm run test -w eat-first-consistency",
    "test:client": "npm run test -w client-consistency",
    "test:ci": "npm run test:wordle && npm run test:eat-first && npm run test:client",
    "test:all": "npm run test:ci",
    "ci": "npm run test:ci && npm run lint && npm run build -w client",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:migrate:dev": "npm run db:migrate:dev -w server",
    "db:migrate:dev:raw": "npm run db:migrate:dev:raw -w server",
    "db:seed": "npm run db:seed -w server",
    "db:generate:server": "npm run db:generate -w server"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "typescript-eslint": "^8.58.1",
    "vue-eslint-parser": "^10.4.0"
  }
}
