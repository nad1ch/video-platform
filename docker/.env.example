# Copy to `docker/.env` in this folder (gitignored) — required for `env_file: .env` in docker-compose.local.yml:
#   cp docker/.env.example docker/.env
#
# OAuth redirect URLs must match what you register in Twitch / Google consoles (API origin :3000, not Vite :5173):
#   http://localhost:3000/api/auth/twitch/callback
#   http://localhost:3000/api/auth/google/callback
#
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- WebRTC / Docker (ICE candidates) ---
# If signaling works but remote video is black: the server may be advertising 127.0.0.1 while the browser
# context is not a shared loopback path (Docker NAT, second tab, incognito, another browser on the LAN).
# Set your host LAN IP (Windows: ipconfig; same machine as Docker Desktop) and open the SPA at that IP:
#   MEDIASOUP_ANNOUNCED_ADDRESS=192.168.0.104
#   NADLE_CLIENT_ORIGIN=http://192.168.0.104:5173
# Optional: VITE_SIGNALING_URL=ws://192.168.0.104:3000 in apps/client/.env.local (same host as API).
#
# Narrow RTC range is already set in docker-compose.local*.yml (55000–55100); override only if needed:
# MEDIASOUP_RTC_MIN_PORT=55000
# MEDIASOUP_RTC_MAX_PORT=55100

# --- TURN (coturn) — optional when direct ICE fails in Docker/Windows ---
# Start coturn: docker compose -f docker/docker-compose.local.yml --profile turn up --build
# Browsers run on the HOST — use 127.0.0.1 or LAN IP in urls, NOT the Docker hostname "coturn".
# Credentials must match coturn --user in compose (default webrtc / change-me).
# Compose publishes relay UDP 49160–49200 alongside 3478 — if you change coturn --min-port/--max-port,
# update the matching `ports:` range in docker-compose*.yml or relay media will never reach the host.
# ICE_SERVERS_JSON=[{"urls":["turn:127.0.0.1:3478?transport=udp","turn:127.0.0.1:3478?transport=tcp"],"username":"webrtc","credential":"change-me"}]
#
# Force relay-only for diagnosis (server sends this to the client on transport options — see clientIceServers.ts):
# ICE_TRANSPORT_POLICY=relay
