# Example coturn config (copy to turnserver.conf and adjust realm / user / external-ip).
# Run: coturn -c /path/to/turnserver.conf
#
# For Docker, prefer command-line flags in docker-compose or mount this file.

listening-port=3478
tls-listening-port=5349
fingerprint
lt-cred-mech
realm=video-platform
server-name=video-platform

# Static user (use strong password in production)
user=webrtc:REPLACE_WITH_STRONG_SECRET

min-port=49152
max-port=65535
verbose

# When behind NAT or in Docker, set the public IP browsers will use for relay candidates:
# external-ip=203.0.113.10
# Or Docker: external-ip=HOST_PUBLIC_IP

no-cli
no-tlsv1
no-tlsv1_1
