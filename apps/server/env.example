# Copy to .env or export in your shell / compose (never commit real secrets).

# =============================================================================
# Minimal LOCAL dev (Vite :5173 + API proxy) — same keys as a typical apps/server/.env
# =============================================================================
# Public SPA origin for CORS + post-login redirects (no trailing slash):
# WORDLE_CLIENT_ORIGIN=http://localhost:5173
# # Alternative supported by server: BASE_URL=http://localhost:5173
#
# Session JWT (>= 16 characters):
# WORDLE_JWT_SECRET=change-me-at-least-16-chars
# # Or: AUTH_JWT_SECRET=...
#
# Email/password users (SQLite). Default: apps/server/data/email_users.sqlite (gitignored).
# EMAIL_USERS_DB_PATH=/var/lib/streamassist/email_users.sqlite
#
# App admin role (StreamAssist shell): comma-separated allowlists (trimmed; emails case-insensitive).
# ADMIN_EMAILS=you@gmail.com,colleague@company.com
# ADMIN_TWITCH_IDS=123456789
#
# PostgreSQL (Prisma). OAuth users + UserStats; optional in dev (OAuth still works without DB).
# DATABASE_URL=postgresql://user:password@localhost:5432/streamassist
#
# Twitch — register BOTH redirect URLs exactly in Twitch Developer Console:
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# TWITCH_AUTH_REDIRECT_URI=http://localhost:5173/api/auth/twitch/callback
# TWITCH_OAUTH_REDIRECT_URI=http://localhost:5173/api/wordle/auth/callback
#
# Google — Authorized redirect URI must match exactly in Google Cloud Console:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
# =============================================================================
#
# =============================================================================
# Production (StreamAssist-style): SPA on app.*, Node on api.* — OAuth callbacks hit API, NOT Pages
# =============================================================================
# Cloudflare Pages cannot run Node; without /api proxy on app, redirect_uri must be on api.*.
#
# BASE_URL=https://app.streamassist.net
# WORDLE_CLIENT_ORIGIN=https://app.streamassist.net
#
# Extra allowed browser origins for credentialed CORS (comma-separated, optional; no trailing slashes).
# CORS_ORIGINS=https://staging.app.streamassist.net
#
# GOOGLE_OAUTH_REDIRECT_URI=https://api.streamassist.net/api/auth/google/callback
# TWITCH_AUTH_REDIRECT_URI=https://api.streamassist.net/api/auth/twitch/callback
# TWITCH_OAUTH_REDIRECT_URI=https://api.streamassist.net/api/wordle/auth/callback
#
# Register the same three URLs in Google Cloud + Twitch Developer Console (exact match).
# Frontend build: VITE_API_URL=https://api.streamassist.net (see apps/client/.env.production.example).
# =============================================================================

# --- mediasoup ICE (fixes recv/send transport "failed" when signaling works) ---
# Address browsers must use to reach this host (public VPS IP or DNS-only media hostname).
# Without this on a real server, candidates are often private/wrong → ICE FAILED.
# MEDIASOUP_ANNOUNCED_ADDRESS=203.0.113.10
#
# RTP/RTCP UDP (and TCP fallback) port range — must match createWorker.ts (rtcMinPort / rtcMaxPort).
# Open the same range on the host firewall and cloud security group, e.g.:
#   sudo ufw allow 40000:49999/udp && sudo ufw allow 40000:49999/tcp

# --- TURN for browsers (coturn or any RFC5766 server) ---
# Option A: full JSON (STUN + TURN). Example with one TURN over UDP/TCP:
# ICE_SERVERS_JSON=[{"urls":["turn:turn.example.com:3478?transport=udp","turn:turn.example.com:3478?transport=tcp"],"username":"webrtc","credential":"your-secret"}]

# Option B: comma-separated URLs + static user (matches lt-cred-mech in coturn)
# TURN_URLS=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp
# TURN_USERNAME=webrtc
# TURN_CREDENTIAL=your-secret

# Force relay-only path (good for verifying TURN; disable in production unless needed)
# ICE_TRANSPORT_POLICY=relay

# --- Logging / disk I/O (stdout is often written to disk by Docker, journald, or log agents) ---
# NODE_ENV=production
# mediasoup media worker subprocess: debug | warn | error | none (default in lib: error)
# MEDIASOUP_WORKER_LOG_LEVEL=error
# Optional pino level for apps/server worker bootstrap logs (trace|debug|info|warn|error|fatal|silent)
# SERVER_PINO_LEVEL=warn

# --- Active speaker (AudioLevelObserver → active-speaker WS) ---
# dBvo threshold (-127..0), interval in ms
# AUDIO_LEVEL_THRESHOLD=-70
# AUDIO_LEVEL_INTERVAL_MS=800
# Delay before broadcasting "no speaker" after silence (reduces UI flicker between phrases)
# AUDIO_SPEAKER_SILENCE_HOLD_MS=1200

# --- Global auth: OAuth, CORS, httpOnly session cookie (cookie name: wordle_session, legacy) ---
# NODE_ENV=production
#
# Public SPA origin (no trailing slash). Required in production for CORS + post-login redirects.
# Prefer one of:
# BASE_URL=https://app.your-domain.com
# WORDLE_CLIENT_ORIGIN=https://app.your-domain.com
#
# JWT signing for session cookie (>= 16 chars; required in production).
# Prefer AUTH_JWT_SECRET; WORDLE_JWT_SECRET still works for older deployments.
# AUTH_JWT_SECRET=change-me-in-production-min-16-chars
# WORDLE_JWT_SECRET=change-me-in-production-min-16-chars
#
# Session cookie (wordle_session): in production Node sets httpOnly, Secure=true, SameSite=None
# (see apps/server/src/auth/sessionCookie.ts). Required for fetch(..., { credentials: 'include' })
# from https://app.* to https://api.*. Use HTTPS everywhere.
#
# OAuth redirect_uri / TWITCH_*_REDIRECT_URI — must be the exact URL where Node receives the callback:
#   • API on its own host: https://api.your-domain.com/api/auth/twitch/callback (typical with Cloudflare Pages + VPS API)
#   • Or app host proxies /api → Node: https://app.your-domain.com/api/auth/twitch/callback
# Register the same string in Twitch / Google consoles.
#
# --- Twitch (register BOTH callback URLs in Twitch Developer Console — exact string match) ---
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
#
# App shell: GET /api/auth/twitch → callback (required in production; dev can omit — server uses BASE_URL)
# TWITCH_AUTH_REDIRECT_URI=https://api.your-domain.com/api/auth/twitch/callback
#
# Wordle embed login: GET …/authorize → this callback (unchanged route)
# TWITCH_OAUTH_REDIRECT_URI=https://api.your-domain.com/api/wordle/auth/callback
#
# --- Google OAuth (optional) — Client ID + secret from Google Cloud Console → APIs & Services → Credentials ---
#
# Local dev (Vite default port; browser hits SPA, proxy forwards /api to the API server):
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
# BASE_URL=http://localhost:5173
#
# Production: BASE_URL / WORDLE_CLIENT_ORIGIN = public SPA (e.g. https://app.your-domain.com) for CORS + post-login redirect.
# GOOGLE_OAUTH_REDIRECT_URI = where Google sends the browser (must hit Node); often API host:
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_OAUTH_REDIRECT_URI=https://api.your-domain.com/api/auth/google/callback
# BASE_URL=https://app.your-domain.com
#
# Optional Apple Sign In (not implemented until you add Service ID + key; $99/year Apple Developer)
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
#
# --- Stream Wordle (Twitch) multi-streamer ---
# Active rows in `Streamer` (Prisma) define which Twitch channels get IRC ingest.
# Without DATABASE_URL in local dev, ingest uses one synthetic room (see DEV_FALLBACK_STREAMER_USERNAME).
# Public JSON: GET /api/wordle/public-config?streamerId=…
# Streamer card: GET /api/streamer/:username
# After Twitch Wordle OAuth, users are redirected to /wordle/<WORDLE_DEFAULT_STREAMER_USERNAME>.
# WORDLE_DEFAULT_STREAMER_USERNAME=nad1ch
# DEV_FALLBACK_STREAMER_USERNAME=nad1ch
#
# IRC read + chat guesses (optional named bot; else anonymous read-only listener).
# TWITCH_IRC_USERNAME=your_bot_login
# TWITCH_IRC_OAUTH=oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Numeric Twitch user id allowed to send WebSocket "next-word"
# TWITCH_ADMIN_USER_ID=123456789
#
# Anti-spam: min ms between guess-shaped chat lines per Twitch user (1000–2500)
# TWITCH_CHAT_GUESS_COOLDOWN_MS=1500
