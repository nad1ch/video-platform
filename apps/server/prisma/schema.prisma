// StreamAssist — minimal persistence (OAuth users + stats). DATABASE_URL required when Prisma is used.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Streamer {
  id        String   @id @default(cuid())
  /// Public slug for `/nadle/:name` (Twitch-style login, lowercase).
  name      String   @unique
  twitchId  String   @unique
  username  String   @unique
  /// User who may administer this streamer row (admin-created).
  ownerId   String?
  owner     User?    @relation("StreamerOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  isActive  Boolean  @default(true)
  members   User[]   @relation("StreamerMembers")
  gameRounds          GameRound[]
  userStreamerStats   UserStreamerStats[]
  nadrawPrompts       NadrawPrompt[]

  @@index([ownerId])
}

/// Crowdsourced drawing-game prompts; `!add` creates unapproved rows for the streamer to moderate.
model NadrawPrompt {
  id          String   @id @default(cuid())
  streamerId  String
  streamer    Streamer @relation(fields: [streamerId], references: [id], onDelete: Cascade)
  text        String
  /// Normalized key for deduplication (lowercase, punctuation stripped, etc.).
  normalizedText String?
  /// `chat` = `!add`; `streamer` = host UI; `system` = seeded rows.
  source      String   @default("chat")
  /// Twitch user id (IRC) of chatter who submitted via `!add`, when known.
  createdBy   String?
  approved    Boolean  @default(false)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([streamerId, approved])
  @@index([streamerId, normalizedText])
  @@map("NadrawPrompt")
}

model User {
  id                 String              @id @default(cuid())
  provider           String
  providerUserId     String
  email              String?             @unique
  displayName        String
  avatarUrl          String?
  role               String
  twitchId           String?             @unique
  streamerId         String?
  streamer           Streamer?           @relation("StreamerMembers", fields: [streamerId], references: [id], onDelete: SetNull)
  ownedStreamers     Streamer[]          @relation("StreamerOwner")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  stats              UserStats?
  userStreamerStats  UserStreamerStats[]

  @@unique([provider, providerUserId])
  @@index([streamerId])
}

// Nadle stats per registered user per streamer room.
model UserStreamerStats {
  id          String   @id @default(cuid())
  userId      String
  streamerId  String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  streamer    Streamer @relation(fields: [streamerId], references: [id], onDelete: Cascade)
  gamesPlayed Int      @default(0)
  wins        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, streamerId])
  @@index([streamerId, wins])
  @@index([userId])
}

model UserStats {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coins       Int      @default(0)
  gamesPlayed Int      @default(0)
  wins        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Nadle stream round snapshot; participant userId strings match gameStore (session id or Twitch IRC id).
model GameRound {
  id           String        @id @default(cuid())
  streamerId String?
  streamer     Streamer?   @relation(fields: [streamerId], references: [id], onDelete: SetNull)
  winnerUserId String
  createdAt    DateTime      @default(now())
  results      GameResult[]

  @@index([streamerId])
  @@index([streamerId, createdAt])
}

model GameResult {
  id       String    @id @default(cuid())
  roundId  String
  round    GameRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  userId   String
  attempts Int
  isWinner Boolean

  @@index([roundId])
  @@index([userId])
}

// Eat-first (party game): replaces client Firestore — room doc + players + votes in Postgres.
model EatFirstGame {
  id        String           @id
  room      Json             @default("{}")
  updatedAt DateTime         @updatedAt
  players   EatFirstPlayer[]
  votes     EatFirstVote[]
}

model EatFirstPlayer {
  id     String       @id @default(cuid())
  gameId String
  game   EatFirstGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  slotId String
  data   Json         @default("{}")

  @@unique([gameId, slotId])
  @@index([gameId])
}

model EatFirstVote {
  id          String       @id @default(cuid())
  gameId      String
  game        EatFirstGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  voterSlotId String
  data        Json         @default("{}")

  @@unique([gameId, voterSlotId])
  @@index([gameId])
}
