# Copy to `apps/server/.env.local` (gitignored) for Prisma + tooling on the HOST.
#   cp apps/server/.env.local.example apps/server/.env.local
#
# Prisma CLI also auto-loads `apps/server/.env` (if it exists) and that value can
# **override** `dotenv-cli -e .env.production` when both define DATABASE_URL. Do not
# leave a placeholder like `@host:5432/...` in any `.env` file.
#
# Repo root: `npm run dev:all` starts Docker Postgres (`db`) + local server + Vite (see docker/README.md).
#
# Inside Docker, DATABASE_URL uses hostname `db` (see docker-compose.local.yml).
# On the host, use localhost because Postgres publishes port 5432.
#
# --- Windows / npm workspaces ---
# • Start Postgres first (e.g. `docker compose -f docker/docker-compose.local.yml up -d db`) or `db:seed` will fail with "Can't reach database server".
# • If `npm install` fails on postinstall with EPERM renaming `query_engine-windows.dll.node`, close processes locking that file (IDE, Node, antivirus), then: `npm install --ignore-scripts` and `npx prisma generate`.
# • `npm run db:migrate:dev` uses `npx dotenv-cli` so the CLI is found when the package is hoisted to the repo root.
# • If you already export DATABASE_URL in the shell, you can use: `npm run db:migrate:dev:raw`
# • From repo root (avoids `cd apps/server` when the path contains spaces): `npm run db:migrate:dev` and `npm run db:seed`
# • After `db:migrate:dev`, run `npm run db:generate:server` (migrate uses `--skip-generate` to reduce Windows EPERM on query_engine rename).
# • Apply committed migrations only (no new migration from drift): `npm run db:migrate` from repo root (`prisma migrate deploy`).

DATABASE_URL=postgresql://streamassist:streamassist@localhost:5432/streamassist

# Session cookie signing (>= 16 characters). Match Docker server vars if you use the same stack.
NADLE_JWT_SECRET=local-docker-dev-secret-min-16-chars
AUTH_JWT_SECRET=local-docker-dev-secret-min-16-chars

# Matches the seeded Google-style user — after OAuth with this email you get admin on /api/admin/*.
ADMIN_EMAILS=admin@local.streamassist

# Eat-first host API uses the session cookie; grant `host` in Admin → Users or use ADMIN_* for full admin.

# Vite default; CORS + redirects for local SPA.
NADLE_CLIENT_ORIGIN=http://localhost:5173

# Same as NADLE_CLIENT_ORIGIN for this stack — email links, wordle client, SPA redirects (server billing/env).
BASE_URL=http://localhost:5173
WORDLE_CLIENT_ORIGIN=http://localhost:5173
APP_ORIGIN=http://localhost:5173

# Email verification links target the API host in dev (verification route lives on the server).
EMAIL_VERIFICATION_ORIGIN=http://localhost:3000

# Optional: webhook HMAC for POST /api/billing/mono-personal/webhook (local testing).
MONO_WEBHOOK_SECRET=local-dev-only-secret
# EMAIL_FROM="StreamAssist <no-reply@localhost>"
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# Twitch OAuth — register the same redirect URL in Twitch Developer Console.
# Recommended for local API (incl. Docker on :3000): callback hits the API directly, no Vite required for that hop.
TWITCH_AUTH_REDIRECT_URI=http://localhost:3000/api/auth/twitch/callback
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
#
# Alternative (Vite-only callback): omit TWITCH_AUTH_REDIRECT_URI and rely on
# {NADLE_CLIENT_ORIGIN}/api/auth/twitch/callback → keep `npm run dev` in apps/client running during login.

# Coin Hub: when NODE_ENV is not `production` (e.g. local `ts-node-dev` with unset NODE_ENV), set to 1 so any
# signed-in user can POST /api/coinhub/spin and /api/coinhub/case/open without daily/case cooldown/lock.
# Production: only `User.role === 'admin'` bypasses; never set this in prod.
# COINHUB_MUTATION_BYPASS=1

# --- Billing: monobank Jar/Banka link + Personal Statement matching (StreamAssist Pro MVP) ---
# Public Jar/Banka URL the user is redirected to in a NEW TAB (we never iframe it).
# Required for POST /api/billing/jar/create-payment-request to succeed.
# This URL is public (anyone with the link can deposit) — not a secret.
# Production:
# MONO_JAR_URL=https://send.monobank.ua/jar/AeE4u5YUjv
#
# Personal API token (id.bank.gov.ua → Особистий API). NEVER expose to frontend.
# Set ONLY in apps/server/.env.local (gitignored). NEVER commit.
# When unset the app stays in manual-review-only mode (no auto-match, admin must approve).
# Discover the matching MONO_ACCOUNT_ID via:
#   node apps/server/scripts/list-mono-accounts.cjs
# MONO_PERSONAL_TOKEN=<personal-api-token>
#
# Monobank account id from /personal/client-info — for Banka/Jar billing this
# MUST be the JAR id (each jar is a separate account in the Personal API),
# NOT the parent card id. Deposits via send.monobank.ua/jar/<short-id> land
# directly on the jar's statement, so the matcher must poll the jar id.
# Required for auto-matching incoming statement items.
# MONO_ACCOUNT_ID=<jar-id-from-list-mono-accounts>
#
# Optional override for the Personal API host (defaults to https://api.monobank.ua).
# MONO_PERSONAL_API_URL=https://api.monobank.ua
#
# Webhook secret for POST /api/billing/mono-personal/webhook. DEFENSE-IN-DEPTH.
# When set, the webhook handler requires either:
#   - request header `X-Mono-Secret: <value>`, or
#   - query param `?secret=<value>` on the registered URL
# and silently drops any other request (still returning 200 so Mono does not retry).
# Without this, an attacker who learned MONO_ACCOUNT_ID (DB foreign key; leaked
# via logs / admin UI / backups) could forge a StatementItem and auto-activate Pro.
# Generate with `openssl rand -hex 24`. Re-register the Mono Personal API webhook URL
# with the query param or add the header via your ingress if you don't control
# the outgoing request shape.
# MONO_WEBHOOK_SECRET=<long-random-string>
#
# Pro plan price (UAH); converted to integer kopecks server-side. Default: 99.
# PRO_PRICE_UAH=99
# Pro window in days granted on auto-match or manual approval. Default: 30.
# PRO_DURATION_DAYS=30
# How long a payment request stays eligible for auto-match before it's marked
# `expired`. Keep tight to reduce ambiguous-collision risk. Default: 15.
# PAYMENT_MATCH_WINDOW_MINUTES=15
#
# Admin notification recipient — receives one email per billing event
# (auto_matched / needs_review / approved / rejected). Idempotent per
# PaymentRequest+event via *EmailSentAt timestamps. When unset, no admin email
# is sent (billing flow keeps working).
# Set the actual ops email in apps/server/.env.local (do NOT commit personal addresses):
# BILLING_NOTIFICATION_EMAIL=ops@streamassist.example
#
# Link included in admin notification emails. Public — safe to commit.
# Production:
# ADMIN_BILLING_REVIEW_URL=https://app.streamassist.net/app/admin/billing
#
# Optional: explicit "From" header for billing emails. Falls back to EMAIL_FROM
# (already used by auth emails) and finally to a localhost no-reply for dev.
# Both auth and billing share the same SMTP transport — see apps/server/src/email/transport.ts.
# SMTP_FROM="StreamAssist Billing <billing@streamassist.example>"
