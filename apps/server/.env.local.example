# Copy to `apps/server/.env.local` (gitignored) for Prisma + tooling on the HOST.
#   cp apps/server/.env.local.example apps/server/.env.local
#
# Inside Docker, DATABASE_URL uses hostname `db` (see docker-compose.local.yml).
# On the host, use localhost because Postgres publishes port 5432.

DATABASE_URL=postgresql://streamassist:streamassist@localhost:5432/streamassist

# Session cookie signing (>= 16 characters). Match Docker server vars if you use the same stack.
WORDLE_JWT_SECRET=local-docker-dev-secret-min-16-chars
AUTH_JWT_SECRET=local-docker-dev-secret-min-16-chars

# Matches the seeded Google-style user — after OAuth with this email you get admin on /api/admin/*.
ADMIN_EMAILS=admin@local.streamassist

# Vite default; CORS + redirects for local SPA.
WORDLE_CLIENT_ORIGIN=http://localhost:5173
