# =============================================================================
# LOCAL DOCKER ONLY — working copy `Dockerfile.local` is gitignored
# =============================================================================
#   cp apps/server/Dockerfile.local.example apps/server/Dockerfile.local
#
# Build context MUST be the repo root (see docker/docker-compose.local.yml).
# Server depends on workspace package `wordle-core` at ../../packages/wordle-core;
# from WORKDIR /app that resolves to /packages/wordle-core (POSIX /app/../../packages).
# =============================================================================

FROM node:20-bullseye

# mediasoup postinstall: prebuilt worker may not match the kernel/glibc in this image; fallback build needs pip (`invoke`).
RUN apt-get update && apt-get install -y \
  python3 \
  python3-pip \
  make \
  g++ \
  build-essential \
  ca-certificates \
  && rm -rf /var/lib/apt/lists/*

# Linked from apps/server via file:../../packages/wordle-core
COPY packages/wordle-core /packages/wordle-core

WORKDIR /app

# Omit apps/server/package-lock.json when it is stale vs package.json (workspace installs use the root lockfile).
COPY apps/server/package.json ./
COPY apps/server/prisma ./prisma/
COPY apps/server/scripts ./scripts/
RUN npm install

COPY apps/server/. .

EXPOSE 3000
# Match docker-compose.local UDP publish + MEDIASOUP_RTC_* (default local example uses 55000–55100).
EXPOSE 55000-55100/udp

CMD ["npm", "run", "dev"]
