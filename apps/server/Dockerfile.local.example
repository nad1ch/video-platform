# =============================================================================
# LOCAL DOCKER ONLY — working copy `Dockerfile.local` is gitignored
# =============================================================================
#   cp apps/server/Dockerfile.local.example apps/server/Dockerfile.local
#
# Used only by docker/docker-compose.local.yml (after you copy the compose example).
# Keeps the default repo Dockerfile free for CI / other environments.
# =============================================================================

FROM node:20-bullseye

# mediasoup postinstall: prebuilt worker may not match the kernel/glibc in this image; fallback build needs pip (`invoke`).
RUN apt-get update && apt-get install -y \
  python3 \
  python3-pip \
  make \
  g++ \
  build-essential \
  ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./
# `postinstall` runs `scripts/prisma-generate-retry.cjs` — copy it + schema before `npm install`.
COPY prisma ./prisma/
COPY scripts/prisma-generate-retry.cjs ./scripts/prisma-generate-retry.cjs
RUN npm install

COPY . .

EXPOSE 3000
# Match docker-compose.local UDP publish + MEDIASOUP_RTC_* (default local example uses 52000–52199).
EXPOSE 52000-52199/udp

CMD ["npm", "run", "dev"]
