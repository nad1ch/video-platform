# --- Eat-first (Firebase + optional analytics + mediasoup signaling) ---
# Copy to .env.local and fill values.
#
# Vite `base`: dev = `/`, production build = `/app/` (see vite.config.ts). Use VITE_API_URL for API host/path overrides.
#
# Global auth (Twitch/Google app shell, /api/auth/*): configure apps/server/.env — not Vite.
# Wordle “Log in with Twitch” (client-built authorize URL) needs the vars below.

# VITE_PUBLIC_CANONICAL_ORIGIN=https://your-app.example.com
# VITE_PLAUSIBLE_DOMAIN=
# VITE_GA_MEASUREMENT_ID=

# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# VITE_FIRESTORE_DEV_PERSIST=true
# VITE_FUNCTIONS_REGION=europe-west1

# Production: same WebSocket signaling as Video call (Eat overlay rooms use gameId).
# VITE_SIGNALING_URL=wss://your-api.example.com

# Video call (/call): optional secret to show manual video quality controls — use ?qualityAdmin=<secret>
# VITE_CALL_QUALITY_ADMIN_SECRET=

# Stream Wordle: on static hosting set absolute WSS to your Node API (not the Pages host).
# VITE_WORDLE_WS_URL=wss://api.your-domain.com/wordle-ws

# Wordle Twitch login (authorize redirect → proxied /api/wordle/auth/callback)
# VITE_TWITCH_CLIENT_ID=
# VITE_TWITCH_OAUTH_REDIRECT_URI=http://localhost:5173/api/wordle/auth/callback

# --- Production (Cloudflare Pages + API subdomain) ---
# Example: app https://app.streamassist.net → API https://api.streamassist.net
# Set in `.env.production` or CI/Pages env (see `.env.production.example`).
# VITE_API_URL=https://api.streamassist.net
#
# If the SPA and API use different origins in production, set the API base (otherwise same-origin /api is used).
# VITE_API_URL=https://api.your-domain.com
#
# Subpath deploy (browser hits /app/api/*; Vite dev rewrites to backend /api/*):
# VITE_API_URL=/app
# Register Twitch redirect URIs with the same prefix, e.g. http://localhost:5173/app/api/auth/twitch/callback
