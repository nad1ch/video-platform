# --- Eat-first (game state via /api/eat-first + Postgres; Firebase block below is legacy / optional) ---
# Copy to `.env.local` and fill values.
#
# Vite `base`: `/` (see vite.config.ts) so production assets are `/assets/*` on the app host root. Use VITE_API_URL if API is on another origin.
#
# --- Local dev: API + signaling on backend :3000 (recommended for Mafia host / WS session cookie) ---
# SPA at http://localhost:5173, API at http://localhost:3000 — set both so fetch and WebSocket hit the same origin as `nadle_session`.
# (Tracked template: `apps/client/.env.local.example` — `cp` to `.env.local`.)
# VITE_API_URL=http://localhost:3000
# VITE_SIGNALING_URL=ws://localhost:3000/ws
#
# Alternative: leave VITE_API_URL unset — Vite proxies `/api` → Node (default http://127.0.0.1:3000; see vite.config.ts).
# You still need VITE_SIGNALING_URL=ws://127.0.0.1:3000/ws (or localhost) so the WebSocket is not anonymous.
#
# Global auth (Twitch/Google app shell, /api/auth/*): configure the **Node server** (e.g. apps/server/.env or docker/.env for Docker).
# If the API listens on another port: VITE_DEV_API_PROXY=http://127.0.0.1:3001
# Nadle “Log in with Twitch” (client-built authorize URL) needs the vars below.

# VITE_PUBLIC_CANONICAL_ORIGIN=https://your-app.example.com
# VITE_PLAUSIBLE_DOMAIN=
# VITE_GA_MEASUREMENT_ID=

# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# VITE_FIRESTORE_DEV_PERSIST=true
# VITE_FUNCTIONS_REGION=europe-west1

# Production: same WebSocket signaling as Video call (Eat overlay rooms use gameId).
# Use the **same host as your API** so the `nadle_session` cookie is sent on the WS upgrade
# (otherwise the server treats the socket as anonymous and Mafia host / auth-bound features break).
# If unset, the client derives wss:// from an absolute `https://` VITE_API_URL (same origin as cookie).
# VITE_SIGNALING_URL=wss://your-api.example.com
#
# Local API in Docker + SPA opened at http://192.168.x.x:5173 — use the same host for WSS (optional if ws://localhost:3000 still works):
# VITE_SIGNALING_URL=ws://192.168.x.x:3000

# Video call manual quality / admin UI: granted by server role (apps/server ADMIN_EMAILS / ADMIN_TWITCH_IDS), not Vite.

# Stream Nadle: on static hosting set absolute WSS to your Node API (not the Pages host).
# VITE_NADLE_WS_URL=wss://api.your-domain.com/nadle-ws
# Optional Nadraw Show WSS override (same pattern as Nadle).
# VITE_NADRAW_WS_URL=wss://api.your-domain.com/nadraw-show-ws

# Default Twitch login for /nadle → /app/nadle/:streamer redirect and nav links (lowercase).
# VITE_DEFAULT_STREAMER=nad1ch

# Nadle Twitch login (authorize redirect → proxied /api/nadle/auth/callback)
# VITE_TWITCH_CLIENT_ID=
# VITE_TWITCH_OAUTH_REDIRECT_URI=http://localhost:5173/api/nadle/auth/callback

# --- Production (Cloudflare Pages + API subdomain) ---
# Example: app https://app.streamassist.net → API https://api.streamassist.net
# Set in `.env.production` or CI/Pages env (see `.env.production.example`).
# VITE_API_URL=https://api.streamassist.net
#
# If the SPA and API use different origins in production, set the API base (otherwise same-origin /api is used).
# VITE_API_URL=https://api.your-domain.com
#
# Subpath deploy (browser hits /app/api/*; Vite dev rewrites to backend /api/*):
# VITE_API_URL=/app
# Register Twitch redirect URIs with the same prefix, e.g. http://localhost:5173/app/api/auth/twitch/callback
