# Production build (e.g. Cloudflare Pages: app at https://app.streamassist.net, API on another host).
# Copy to `.env.production` or set the same keys in Pages → Settings → Environment variables.

# Required when the SPA and API are on different origins (otherwise browser uses relative `/api/...` and OAuth breaks).
VITE_API_URL=https://api.streamassist.net

# Google/Twitch app-shell OAuth callbacks are configured on the API server (GOOGLE_OAUTH_REDIRECT_URI, TWITCH_AUTH_REDIRECT_URI).
# If Node lives on api.*, use https://api.streamassist.net/api/auth/google/callback (same string in Google Cloud).

# Wordle “Log in with Twitch” (browser → id.twitch.tv): redirect_uri must match Twitch Console AND server TWITCH_OAUTH_REDIRECT_URI.
# If callbacks go to the API host:
# VITE_TWITCH_OAUTH_REDIRECT_URI=https://api.streamassist.net/api/wordle/auth/callback
# VITE_TWITCH_CLIENT_ID=your_twitch_client_id
