# Copied to .env.production locally (gitignored) or set in Vercel → Environment Variables.
# HTTPS pages require wss:// — plain ws:// causes mixed content / blocked WebSocket.
#
# Example (your VPS IP, non-TLS — OK only for http:// origins; Vercel https:// needs TLS on signaling):
# VITE_SIGNALING_URL=ws://178.104.160.220:3000
#
# Preferred in production behind nginx + certbot:
# VITE_SIGNALING_URL=wss://your-domain.com
VITE_SIGNALING_URL=
