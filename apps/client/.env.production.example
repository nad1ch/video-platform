# Copy to .env.production (local, gitignored) or set in Cloudflare Pages / Vercel → Environment Variables.
#
# HTTPS pages require wss:// (mixed content blocks ws://).
#
# --- Split DNS (recommended when the apex is behind Cloudflare “Proxied”) ---
# Put the SPA on e.g. app.example.com (proxied) and mediasoup + signaling on a DNS-only host:
#   media.example.com  →  your VPS (grey cloud / DNS only)
# Then point signaling at media, NOT at the proxied apex (UDP/WebRTC + stable WS):
#
# VITE_SIGNALING_URL=wss://media.example.com/ws
#
# If you set only the origin (e.g. wss://media.example.com), the client appends /ws automatically.
#
# --- Generic placeholder ---
VITE_SIGNALING_URL=wss://media.your-domain.com/ws
